)

test_suite(
    name = "false_positive_repros",
    tests = [
        ":commonjs_require_false_positive_repro",
        ":dynamic_import_destructuring_false_positive_repro",
        ":import_meta_glob_false_positive_repro",
        ":test_helper_imports_false_positive_repro",
    ],
