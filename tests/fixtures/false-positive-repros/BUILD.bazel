        ":dynamic_import_destructuring_files",
        "dynamic_import_destructuring/codescythe.json",
    ],
    expected_exit_code = 0,
    must_not_contain = ["lazyValue"],
)

filegroup(
    name = "import_meta_glob_files",
    srcs = glob(["import_meta_glob/**"]),
)

codescythe_test(
