common --enable_bzlmod
common --enable_platform_specific_config
common --repo_env=BAZEL_DO_NOT_DETECT_CPP_TOOLCHAIN=1
common --repo_env=BAZEL_NO_APPLE_CPP_TOOLCHAIN=1
common --@llvm//config:experimental_stub_libgcc_s=True
common:linux --host_platform=//platforms:local_linux_gnu

build:linux_amd64 --platforms=//crates/codescythe_napi/platforms:linux_amd64_musl
build:linux_arm64 --platforms=//crates/codescythe_napi/platforms:linux_arm64_musl
build:darwin_arm64 --platforms=//crates/codescythe_napi/platforms:darwin_arm64
build:linux --@rules_go//go/config:gc_linkopts=-extldflags,-no-pie

test --test_output=errors
